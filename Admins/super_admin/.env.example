# Super Admin Environment Variables (copy to .env when deploying)
# NOTE: The Super Admin app loads the root .env (../../.env) by default.
# This file is provided as a convenient local template for your super_admin folder.

# ----------------------
# SUPABASE / AUTH
# ----------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# ----------------------
# LENCO (PAYMENTS)
# ----------------------
# Used by the payout execution path in the Super Admin area
LENCO_ENV=live
LENCO_API_KEY=your_lenco_api_key_here
LENCO_API_BASE=https://api.lenco.co/access/v2

# Optional: widget keys for interactive payments
LENCO_PUBLIC_KEY_SNDBOX=pub-your-sandbox-public-key
LENCO_SECRET_KEY_SANDBOX=your-sandbox-secret-key
LENCO_PUBLIC_KEY_LIVE=pub-your-live-public-key
LENCO_SECRET_KEY_LIVE=your-live-secret-key

# ----------------------
# APPLICATION
# ----------------------
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost
SESSION_TIMEOUT=1800
