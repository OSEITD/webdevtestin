# Outlet App — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Supabase project URL  (Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (public) key — safe for server-side reads with RLS
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase service-role key — bypasses RLS, KEEP THIS SECRET
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Application environment: development | production
ENVIRONMENT=production

# Lenco Payment Gateway — obtain from https://dashboard.lenco.co
# LENCO_ENV: 'live' for production, 'sandbox' for testing
LENCO_ENV=live

# Optional overrides (if you want a different API host or key)
# These are used by the payout service and do not affect widget loading.
LENCO_API_BASE=https://api.lenco.co/access/v2
LENCO_API_KEY=your-live-api-key-here

# Standard keys (used by the widget and verification flow)
LENCO_PUBLIC_KEY_LIVE=pub-your-live-public-key-here
LENCO_SECRET_KEY_LIVE=your-live-secret-key-here
LENCO_PUBLIC_KEY_SANDBOX=pub-your-sandbox-public-key-here
LENCO_SECRET_KEY_SANDBOX=your-sandbox-secret-key-here
