# ---------------------------------------------------------------
# Customer App – Apache security rules
# ---------------------------------------------------------------

# Block all .env files from being served over HTTP
<FilesMatch "^\.env(\..*)?$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block log files
<FilesMatch "\.log$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block backup / temporary files
<FilesMatch "\.(bak|backup|old|swp|swo)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block direct access to composer config
<FilesMatch "^composer\.(json|lock)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Prevent directory listing
Options -Indexes

# Disable PHP error display for all files (only log, never show)
php_flag  display_errors  off
php_flag  log_errors      on
